    {
      "id": "scene-update-warmer-light",
      "utterance": "把孩子屋开灯改成暖一点，别太刺眼",
      "expectedIntent": "scene.update",
      "request": {
        "contractVersion": "1.0",
        "requestId": "natural-scene-update-warmer",
        "locale": "zh-CN",
        "utterance": "把孩子屋开灯改成暖一点，别太刺眼",
        "intent": "scene.update",
        "targets": [
          {
            "entityType": "scene",
            "name": "孩子屋开灯"
          }
        ],
        "parameters": {
          "houseId": "house-1",
          "sceneId": "scene-1",
          "name": "孩子屋开灯",
          "actions": [
            {
              "targetType": "device",
              "targetId": "device-1",
              "targetName": "孩子屋吸顶灯",
              "rank": 0,
              "set": {
                "power": true,
                "brightness": 45,
                "colorTemperature": 3000
              }
            }
          ]
        }
      },
      "checks": [
        "completeActionRows"
      ]
    },
